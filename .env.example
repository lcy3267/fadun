# ── Server ──────────────────────────────────────────
PORT=3000
JWT_SECRET=change_this_to_a_long_random_string_in_production
# 逗号分隔；前端与 API 不同域时必须包含前端页面 origin（如 https://app.example.com）
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ── Client（Vite 构建读根目录 .env）──────────────────
# 默认 /api（与页面同源 + 反向代理）。纯静态前端与 API 分域时设为完整 API 前缀，如 https://api.example.com/api
# VITE_API_BASE=/api

# ── Database ─────────────────────────────────────────
DATABASE_URL="file:./fadun.db"

# ── LLM Provider 配置 ────────────────────────────────
# 可选值：anthropic（默认） | openai
LLM_PROVIDER=openai

# --- Anthropic Claude（LLM_PROVIDER=anthropic 时使用）---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

OPENAI_API_KEY=sk-or-v1-
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=deepseek/deepseek-v3.2
OPENAI_V_MODEL=z-ai/glm-4.6v

# 可选：embedding 单独走一个 provider（推荐填 OpenAI 官方，避免 OpenRouter 无可用上游）
EMBEDDING_API_KEY=XX
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_MODEL=embedding-3
