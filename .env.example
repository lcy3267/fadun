# ── Server ──────────────────────────────────────────
PORT=3000
JWT_SECRET=change_this_to_a_long_random_string_in_production

# ── Database ─────────────────────────────────────────
DATABASE_URL="file:./fadun.db"

# ── LLM Provider 配置 ────────────────────────────────
# 可选值：anthropic（默认） | openai | deepseek
LLM_PROVIDER=anthropic

# --- Anthropic Claude（LLM_PROVIDER=anthropic 时使用）---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# --- OpenAI（LLM_PROVIDER=openai 时使用）---------------
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# --- DeepSeek（LLM_PROVIDER=deepseek 时使用）-----------
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx   ← 填 DeepSeek 的 key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

OPENAI_API_KEY=sk-or-v1-
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=deepseek/deepseek-v3.2
OPENAI_V_MODEL=z-ai/glm-4.6v

