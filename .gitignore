# Dependencies & build
node_modules/
dist/
client/dist/

# Secrets & local env
.env
.env.local
.env.*.local

# Logs (any location)
*.log
logs/
server/src/logs/

# SQLite (Prisma / local dev)
server/prisma/*.db
server/prisma/*.db-journal
server/prisma/*.db-shm
server/prisma/*.db-wal
# 若 DATABASE_URL 指向 server 根目录下的 db，一并忽略
server/*.db
server/*.db-journal

# Runtime uploads & generated RAG index (do not commit user data / vectors)
server/uploads/*
!server/uploads/.gitkeep
server/.rag/
server/data/

# OS & editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Optional tooling
coverage/
*.tsbuildinfo
.turbo/

# Keep lockfile in repo for reproducible installs — do not ignore package-lock.json
