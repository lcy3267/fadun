generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  password  String
  createdAt DateTime @default(now())
  cases     Case[]
  tasks     Task[]
  agentRuns AgentRun[]
  notifications Notification[]
  chatSessions ChatSession[]
}

model Case {
  id          Int        @id @default(autoincrement())
  userId      Int
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDemo      Boolean    @default(false)
  type        String
  goal        String
  desc        String
  status      String     @default("active") // active | done
  groups      String     @default("[]")     // JSON array of group names
  guide       String     @default("[]")     // JSON array of guide objects
  analysis    String?                        // JSON object
  caseSummary String?                        // JSON object (evidence-driven summary)
  doc         String?                        // JSON object
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  plaintiff   Plaintiff?
  defendant   Defendant?
  evidence    Evidence[]
  tasks       Task[]
  agentRuns   AgentRun[]
  notifications Notification[]
  chatSessions ChatSession[]
}

model Plaintiff {
  id      Int    @id @default(autoincrement())
  caseId  Int    @unique
  case    Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  name    String
  gender  String @default("male")
  age     Int
  region  String
}

model Defendant {
  id      Int    @id @default(autoincrement())
  caseId  Int    @unique
  case    Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  name    String
  gender  String @default("male")
  idNo    String @default("")
  huji    String @default("")
  rel     String
}

model Evidence {
  id         Int      @id @default(autoincrement())
  caseId     Int
  case       Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  filename   String
  filepath   String   // server path relative to uploads/
  ext        String   @default("")
  size       Int      @default(0)
  sha256     String   @default("")
  text       String?
  meta       String?  // JSON string
  processedAt DateTime?
  ocrText    String?
  mimetype   String
  status     String   @default("pending") // pending | valid | invalid
  evType     String   @default("")
  group      String?
  verdict    String   @default("")
  aiVerified Boolean  @default(false)   // true = 已识别，禁止再次认证
  isDemo     Boolean  @default(false)   // placeholder evidence in demo case
  createdAt  DateTime @default(now())
}

model Task {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseId    Int?
  case      Case?    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type      String
  status    String   @default("queued") // queued | running | succeeded | failed | canceled
  progress  Int      @default(0)
  payload   String   // JSON string
  result    String?  // JSON string
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentRun {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseId    Int?
  case      Case?    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type      String
  status    String   @default("queued") // queued | running | succeeded | failed | canceled
  progress  Int      @default(0)
  messages  String?  // JSON string (array of {role,content} or tool steps)
  lastTool  String?
  lastResult String?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseId    Int?
  case      Case?    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  level     String   @default("info") // info | warn | error
  message   String
  meta      String?  // JSON string
  createdAt DateTime @default(now())
}

model ChatSession {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseId    Int
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  status    String   @default("active") // active | closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  sessionId Int
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String   // user | assistant | system
  content   String
  meta      String?  // JSON string
  createdAt DateTime @default(now())
}
